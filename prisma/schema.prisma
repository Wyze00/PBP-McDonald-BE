generator client {
  provider = "prisma-client"
  output   = "./generated/"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  KITCHEN
}

model User {
  id        String    @id @default(uuid()) @db.VarChar(100)
  username  String    @unique @db.VarChar(20)
  password  String    @db.VarChar(100)
  role      Role
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  deletedAt DateTime?

  @@map("users")
}

model Product {
  id                  String    @id @default(uuid()) @db.VarChar(100)
  name                String    @unique @db.VarChar(100)
  description         String    @db.Text
  imageUrl            String    @db.VarChar(255)
  price               Int
  product_category_id String    @db.VarChar(100)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime?
  deletedAt           DateTime?

  orders          OrderProduct[]
  productCategory ProductCategory @relation(fields: [product_category_id], references: [id])

  @@map("products")
}

model ProductCategory {
  id   String @id @default(uuid()) @db.VarChar(100)
  name String @unique @db.VarChar(100)

  products Product[]

  @@map("prouct_categories")
}

enum OrderStatus {
  READY
  CANCELED
  ONGOING
  COMPLETED
}

model Order {
  id             String      @id @default(uuid()) @db.VarChar(100)
  orderDate      DateTime    @default(now()) @db.Date
  orderTimestamp DateTime    @default(now()) @db.Timestamp()
  orderNumber    Int
  status         OrderStatus
  updatedAt      DateTime?

  orderedProductsDetails OrderProduct[]
  orderTransaction       OrderTransaction?

  @@unique([orderDate, orderNumber])
  @@map("orders")
}

model OrderProduct {
  id         String @id @default(uuid()) @db.VarChar(100)
  order_id   String @db.VarChar(100)
  product_id String @db.VarChar(100)
  quantity   Int

  product Product @relation(fields: [product_id], references: [id])
  order   Order   @relation(fields: [order_id], references: [id])

  @@unique([order_id, product_id])
  @@map("order_products_details")
}

enum PaymentMethod {
  CASH
  QRIS
  CARD
}

enum OrderTransactionStatus {
  CANCELED
  SUCCESS
}

model OrderTransaction {
  id             String                 @id @default(uuid()) @db.VarChar(100)
  order_id       String                 @unique @db.VarChar(100)
  paymentMehthod PaymentMethod
  totalCost      Int
  status         OrderTransactionStatus @default(SUCCESS)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime?

  order Order @relation(fields: [order_id], references: [id])

  @@map("order_transactions")
}
