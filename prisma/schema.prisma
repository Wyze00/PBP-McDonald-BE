generator client {
  provider = "prisma-client"
  output   = "./generated/"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  KITCHEN
}

model User {
  id String @id @db.VarChar(100) @default(uuid())
  username String @db.VarChar(20) @unique
  password String @db.VarChar(100)
  email String @db.VarChar(100) @unique
  role Role
  createdAt DateTime @default(now())
  updatedAt DateTime?
  deletedAt DateTime?
  resetPasswordToken String? @db.VarChar(50)
  resetPasswordExpires DateTime?

  @@map("users")
}

model Product {
  id String @id @db.VarChar(100) @default(uuid())
  name String @db.VarChar(100) @unique
  description String @db.Text
  imageUrl String @db.VarChar(255)
  price Int
  product_category_id String @db.VarChar(100)

  orders OrderProduct[]
  productCategory ProductCategory @relation(fields: [product_category_id], references: [id])
  @@map("products")
}

model ProductCategory {
  id String @id @db.VarChar(100) @default(uuid())
  name String @db.VarChar(100) @unique
  
  products Product[]
  @@map("prouct_categories")
}

enum OrderStatus {
  READY
  CANCELED
  ONGOING
  COMPLETED
}

model Order {
  id String @id @db.VarChar(100) @default(uuid())
  orderDate DateTime @db.Date @default(now())
  orderTimestamp DateTime @db.Timestamp() @default(now())
  orderNumber Int
  status OrderStatus

  orderedProductsDetails OrderProduct[]
  orderTransaction OrderTransaction?

  @@unique([orderDate, orderNumber])
  @@map("orders")
}

model OrderProduct {
  id String @id @db.VarChar(100) @default(uuid())
  order_id String @db.VarChar(100)
  product_id String @db.VarChar(100)
  quantity Int

  product Product @relation(fields: [product_id], references: [id])
  order Order @relation(fields: [order_id], references: [id])

  @@unique([order_id, product_id])
  @@map("order_products_details")
}

enum PaymentMethod {
  CASH
  QRIS
  CARD  
}

enum OrderTransactionStatus {
  CANCELED
  SUCCESS
}

model OrderTransaction {
  id String @id @db.VarChar(100) @default(uuid())
  order_id String @db.VarChar(100) @unique
  paymentMehthod PaymentMethod
  totalCost Int 
  status OrderTransactionStatus @default(SUCCESS)

  order Order @relation(fields: [order_id], references: [id])

  @@map("order_transactions")
}